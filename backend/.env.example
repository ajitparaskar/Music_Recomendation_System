# Copy to .env and fill in (never commit real secrets)
FLASK_ENV=development

JWT_SECRET_KEY=change-me-in-production-min-32-chars
SECRET_KEY=optional-flask-session-secret

MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=music_db

# Path to Spotify tracks CSV (default: backend/dataset.csv)
# DATASET_PATH=

YOUTUBE_API_ENABLED=true
# YOUTUBE_API_KEY=

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
